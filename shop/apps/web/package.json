{
  "name": "shop-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview --port 5173",
    "lint": "eslint ."
  },
  "reactSnap": {
    "source": "dist",
    "minifyHtml": {
      "collapseWhitespace": true,
      "removeComments": true
    },
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "crawl": true,
    "include": [
      "/",
      "/search",
      "/blog",
      "/page/about",
      "/page/contact",
      "/page/faq",
      "/page/shipping",
      "/page/returns",
      "/page/privacy",
      "/page/terms"
    ],
    "skipThirdPartyRequests": true,
    "cacheAjaxRequests": false,
    "removeBlobs": true,
    "fixWebpackChunksIssue": "CRA2",
    "removeStyleTags": false,
    "preloadImages": true
  },
  "overrides": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.2",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "dompurify": "^3.0.6",
    "framer-motion": "^12.23.26",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.4.1",
    "react-player": "^2.14.1",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.0",
    "terser": "^5.26.0",
    "vite": "^5.0.10"
  }
}
