{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://api.vtechkitchen.com/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://api.vtechkitchen.com/robots.txt"
    },
    {
      "source": "/((?!assets|static|sitemap.xml|robots.txt).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
