# Server
NODE_ENV=development
PORT=8080
APP_URL=http://localhost:8080
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/shop

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Secrets - CRITICAL: Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit real secrets to version control!
# These MUST be set - application will not start without them (64+ chars required)
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS_MIN
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Legacy support (will be deprecated - use JWT_* variables above)
ACCESS_TOKEN_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS_MIN
REFRESH_TOKEN_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS_MIN

# Email Configuration (MailerSend)
# Get your API key from: https://app.mailersend.com/api-tokens
MAILERSEND_API_KEY=mlsn.xxxxxxxxxxxx
MAIL_FROM="Your Store <MS_xxxxx@trial-xxxxx.mlsender.net>"
REPLY_TO_EMAIL=vtechshop.customercare@gmail.com
REPLY_TO_NAME=VTech Support
ADMIN_EMAIL=admin@yourstore.com
SUPPORT_EMAIL=support@yourstore.com
SUPPORT_PHONE=+91-1234567890

# Storage (local, cloudinary, or s3)
UPLOAD_DRIVER=local

# Cloudinary (recommended for production - free tier: 25GB)
# Get your credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payment (Optional - leave empty for development)
STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Analytics (Optional)
GA4_MEASUREMENT_ID=
META_PIXEL_ID=

# Logging
LOG_LEVEL=info

# Ads
AD_CLICK_SESSION_TTL_MIN=30
AD_BUDGET_MIN=8000

# Affiliate
AFFILIATE_WINDOW_DAYS=30

# Tax Configuration
DEFAULT_TAX_RATE=0.18

# Shipping Provider Configuration
# Configure one or more shipping providers - they will be automatically enabled

# Delhivery (Indian domestic shipping)
# Get your tokens from: https://ucp.delhivery.com → Settings → API Setup
# Test token for staging environment (staging-express.delhivery.com)
DELHIVERY_TEST_TOKEN=
# Live token for production environment (api.delhivery.com)
DELHIVERY_LIVE_TOKEN=cea77f69361ecff1dd8da6e618d954ba3fd035f9

# Shiprocket (Multi-carrier aggregator)
# Get credentials from: https://app.shiprocket.in/seller/settings/api
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# BlueDart Express (Premium courier)
# Get credentials from: https://www.bluedart.com/
BLUEDART_LICENSE_KEY=
BLUEDART_LOGIN_ID=
BLUEDART_API_URL=https://netconnect.bluedart.com

# Note: At least one shipping provider must be configured for production
# In development, mock carriers are used automatically

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
CSRF_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS_MIN
